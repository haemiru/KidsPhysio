# ─────────────────────────────────────────────
# Supabase (클라이언트 — VITE_ 접두사는 브라우저 노출됨, anon key만!)
# ─────────────────────────────────────────────
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─────────────────────────────────────────────
# 서버 전용 (Vercel Serverless /api 에서만 사용 — 절대 VITE_ 접두사 금지)
# ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Vercel Cron 보호용 (선택)
CRON_SECRET=

# Solapi (카카오 알림톡)
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
SOLAPI_SENDER_PHONE=01000000000
SOLAPI_PFID=your-kakao-pfid
# 알림톡 템플릿 ID (솔라피 콘솔에서 승인된 템플릿)
SOLAPI_TPL_BOOKING_CONFIRMED=
SOLAPI_TPL_NEW_APPLICATION_HOST=
SOLAPI_TPL_REMINDER=
SOLAPI_TPL_PAYMENT_REQUEST=
SOLAPI_TPL_LOOKUP=
# 본인 예약 조회 매직링크 도메인 (예: https://regist-form.vercel.app). 미설정 시 요청 host 사용
APP_ORIGIN=

# 호스트(관리자) 알림 수신 번호
HOST_NOTIFY_PHONE=01000000000

# 토스페이먼츠
TOSS_SECRET_KEY=test_sk_your-toss-secret
VITE_TOSS_CLIENT_KEY=test_ck_your-toss-client-key

# 무통장 입금 계좌 안내 (서버에서 BANK_INFO, 클라이언트 표시는 VITE_BANK_INFO)
BANK_INFO=국민은행 000000-00-000000 (예금주: 피지오후각연구소)
VITE_BANK_INFO=국민은행 000000-00-000000 (예금주: 피지오후각연구소)
